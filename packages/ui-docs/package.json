{
  "name": "@luminescent/ui-docs",
  "description": "Luminescent UI Documentation",
  "private": true,
  "engines": {
    "node": ">=23.11.0"
  },
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/cloudflare-workers/vite.config.ts",
    "build.types": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview",
    "serve": "wrangler dev",
    "start": "vite --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "sideEffects": false,
  "devDependencies": {
    "@anuragroy/tailwindcss-animate": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@eslint/js": "^10.0.1",
    "@luminescent/icons-qwik": "workspace:*",
    "@luminescent/ui": "workspace:*",
    "@luminescent/ui-qwik": "workspace:*",
    "@qwik.dev/core": "2.0.0-beta.29",
    "@qwik.dev/router": "2.0.0-beta.29",
    "@tailwindcss/vite": "^4.2.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-plugin-qwik": "2.0.0-beta.29",
    "globals": "^17.4.0",
    "lucide-icons-qwik": "0.577.0-qwik-v2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-icons-qwik": "16.12.0-qwik-v2",
    "tailwindcss": "^4.2.1",
    "ts-morph": "27",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "^7.24.3",
    "vite": "8.0.0",
    "wrangler": "^4.73.0"
  }
}
