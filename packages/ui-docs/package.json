{
  "name": "@luminescent/ui-docs",
  "description": "Luminescent UI Documentation",
  "private": true,
  "engines": {
    "node": ">=23.11.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vp build",
    "build.preview": "vp build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vp build -c adapters/cloudflare-workers/vite.config.ts",
    "build.types": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "preview": "qwik build preview && vp preview",
    "serve": "wrangler dev",
    "start": "vp dev --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "sideEffects": false,
  "devDependencies": {
    "@luminescent/icons-qwik": "workspace:*",
    "@luminescent/ui": "workspace:*",
    "@luminescent/ui-qwik": "workspace:*",
    "@qwik.dev/core": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/core@8785",
    "@qwik.dev/router": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/router@8785",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "globals": "^17.7.0",
    "lucide-icons-qwik": "1.16.0-qwik-v2",
    "oxlint-plugin-qwik": "^0.0.9",
    "simple-icons-qwik": "16.19.0-qwik-v2",
    "tailwindcss": "^4.3.2",
    "ts-morph": "28",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "latest",
    "undici": "^8.7.0",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.110.0",
    "vite-plus": "catalog:"
  }
}
