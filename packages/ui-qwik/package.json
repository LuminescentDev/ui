{
  "name": "@luminescent/ui-qwik",
  "version": "7.0.0-11",
  "description": "Luminescent UI library - Qwik",
  "main": "./lib/index.qwik.mjs",
  "qwik": "./lib/index.qwik.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.qwik.mjs",
      "require": "./lib/index.qwik.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "license": "AGPL-3.0-or-later",
  "private": false,
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "qwik build",
    "build.lib": "vite build --mode lib",
    "build.types": "tsc -p tsconfig.types.json --emitDeclarationOnly --incremental false",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "release": "np",
    "start": "vite --open --mode ssr",
    "test": "echo \"No test specified\" && exit 0",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@qwik.dev/core": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/core@8785",
    "@qwik.dev/router": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/router@8785",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-qwik": "https://pkg.pr.new/QwikDev/qwik/eslint-plugin-qwik@8785",
    "globals": "17.7.0",
    "np": "^11.2.2",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4"
  },
  "peerDependencies": {
    "@luminescent/ui": "workspace:*"
  }
}