{
  "name": "@luminescent/icons-qwik",
  "version": "0.1.1",
  "private": false,
  "description": "a small icon library",
  "homepage": "https://ui.luminescent.dev",
  "bugs": {
    "url": "https://github.com/LuminescentDev/ui/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "saboooor",
    "url": "https://saboor.ca"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LuminescentDev/ui.git"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.qwik.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.qwik.mjs",
      "require": "./lib/index.qwik.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "qwik build",
    "build.lib": "vp build --mode lib",
    "build.types": "tsc -p tsconfig.types.json --emitDeclarationOnly --incremental false",
    "dev": "vp dev --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "release": "np",
    "start": "vp dev --open --mode ssr",
    "test": "echo \"No test specified\" && exit 0",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@qwik.dev/core": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/core@8785",
    "@qwik.dev/router": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/router@8785",
    "@types/node": "25.5.0",
    "globals": "17.4.0",
    "np": "^11.0.2",
    "oxlint-plugin-qwik": "^0.0.9",
    "typescript": "5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "qwik": "./lib/index.qwik.mjs"
}
