{
  "name": "@luminescent/ui-react",
  "version": "6.8.3-1",
  "private": false,
  "description": "Luminescent UI library - React",
  "homepage": "https://ui.luminescent.dev",
  "bugs": {
    "url": "https://github.com/LuminescentDev/ui/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "saboooor",
    "url": "https://saboor.ca"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LuminescentDev/ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/ui-react.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "vp dev",
    "dev": "vp dev",
