    "build.types": "tsc --emitDeclarationOnly",
    "preview": "vp preview"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "globals": "^16.5.0",
    "oxlint-plugin-qwik": "^0.0.9",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vite-plugin-dts": "^4.5.4",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@luminescent/ui": "workspace:*"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=23.11.0"
  }
